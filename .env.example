# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# PostgreSQL
POSTGRES_DB=rate_tracker
POSTGRES_USER=rate_tracker
POSTGRES_PASSWORD=rate_tracker
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# API
INGEST_BEARER_TOKEN=dev-ingest-token-change-me
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Data / dbt
SEED_PARQUET_PATH=/data/rates_seed.parquet
DBT_PROJECT_DIR=/dbt
DBT_PROFILES_DIR=/dbt
DBT_RUN_AFTER_INGEST=true

# Container startup (production entrypoint.sh)
RUN_MIGRATIONS=true
RUN_DBT_ON_STARTUP=true

# Observability
SLOW_QUERY_THRESHOLD_MS=200
LOG_LEVEL=INFO

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api
